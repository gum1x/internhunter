ANTHROPIC_API_KEY=
INTERNHUNTER_DB_PATH=internhunter.db
INTERNHUNTER_HTTP_CONCURRENCY=16
INTERNHUNTER_PER_HOST_CONCURRENCY=4
INTERNHUNTER_DEFAULT_USER_AGENT=InternHunter/0.1 (+https://github.com/internhunter)
INTERNHUNTER_REQUEST_TIMEOUT=30.0
INTERNHUNTER_CACHE_DIR=.cache
INTERNHUNTER_RETRY_MAX_ATTEMPTS=4
INTERNHUNTER_EMBED_MODEL=all-MiniLM-L6-v2
INTERNHUNTER_PROFILE_PATH=internhunter/config/profile.yaml
INTERNHUNTER_BROWSER_ENGINE=playwright
INTERNHUNTER_BROWSER_HEADLESS=true
INTERNHUNTER_ENABLE_BROWSER=false
INTERNHUNTER_LLM_MODEL=claude-opus-4-8
INTERNHUNTER_LLM_BACKEND=auto
INTERNHUNTER_LLM_MAX_TOKENS=1024
INTERNHUNTER_NOTIFY_MIN_FIT=0.6
INTERNHUNTER_DISCORD_WEBHOOK_URL=
INTERNHUNTER_NTFY_TOPIC_URL=
INTERNHUNTER_SEARXNG_URL=http://localhost:8888
