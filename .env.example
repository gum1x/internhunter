ANTHROPIC_API_KEY=
INTERNHUNTER_DB_PATH=internhunter.db
INTERNHUNTER_HTTP_CONCURRENCY=16
INTERNHUNTER_PER_HOST_CONCURRENCY=4
INTERNHUNTER_DEFAULT_USER_AGENT=InternHunter/0.1 (+https://github.com/internhunter)
INTERNHUNTER_REQUEST_TIMEOUT=30.0
INTERNHUNTER_CACHE_DIR=.cache
INTERNHUNTER_RETRY_MAX_ATTEMPTS=4
INTERNHUNTER_EMBED_MODEL=all-MiniLM-L6-v2
INTERNHUNTER_PROFILE_PATH=internhunter/config/profile.yaml
INTERNHUNTER_BROWSER_ENGINE=playwright
INTERNHUNTER_BROWSER_HEADLESS=true
INTERNHUNTER_ENABLE_BROWSER=false
INTERNHUNTER_LLM_MODEL=claude-opus-4-8
INTERNHUNTER_LLM_BACKEND=auto
INTERNHUNTER_LLM_MAX_TOKENS=1024
INTERNHUNTER_NOTIFY_MIN_FIT=0.6
INTERNHUNTER_DISCORD_WEBHOOK_URL=
INTERNHUNTER_NTFY_TOPIC_URL=
INTERNHUNTER_SEARXNG_URL=http://localhost:8888
INTERNHUNTER_ENABLE_BROWSER=true
INTERNHUNTER_LINKEDIN_KEYWORDS=intern,co-op,"summer intern","software engineer intern"
INTERNHUNTER_ENABLE_LINKEDIN_AUTH=true
INTERNHUNTER_ENABLE_HANDSHAKE_AUTO=true
INTERNHUNTER_HANDSHAKE_EDU_POOL=
INTERNHUNTER_ENABLE_SESSION_REFRESH=true
INTERNHUNTER_RERESOLVE_BUDGET_SECONDS=600
INTERNHUNTER_CRTSH_MAX_DOMAINS=50
INTERNHUNTER_TELEGRAM_CHANNELS=
INTERNHUNTER_ENABLE_SCHEDULED_LLM_RATING=true
INTERNHUNTER_LLM_RATING_TOP_K=0
INTERNHUNTER_LLM_MODEL=haiku
INTERNHUNTER_LLM_BACKEND=cli

# Pillar 1 — Greenhouse global job-ID frontier crawler
INTERNHUNTER_GREENHOUSE_FRONTIER_WINDOW=1500
INTERNHUNTER_GREENHOUSE_FRONTIER_INTERVAL_MIN=60

# Pillar 2 — government hiring-disclosure intelligence (OFLC LCA/PERM + SBIR/STTR)
INTERNHUNTER_OFLC_SOC_PREFIXES=15-12
INTERNHUNTER_OFLC_LCA_URL=
INTERNHUNTER_SBIR_API_URL=https://api.www.sbir.gov/public/api/awards
INTERNHUNTER_DISCLOSURE_USER_AGENT=

# --- push alert pipeline (Telegram) ---
INTERNHUNTER_TELEGRAM_BOT_TOKEN=
INTERNHUNTER_TELEGRAM_CHAT_ID=
INTERNHUNTER_ENABLE_SCHEDULED_NOTIFY=true
INTERNHUNTER_NOTIFY_INTERVAL_MIN=30
INTERNHUNTER_NOTIFY_LOOKBACK_HOURS=48
INTERNHUNTER_NOTIFY_MAX_PER_RUN=20
INTERNHUNTER_NOTIFY_REQUIRE_TARGET_MATCH=false
INTERNHUNTER_NOTIFY_TRACK_ALERTS=true

# --- targets / referral engine (paths to the two user-editable files) ---
INTERNHUNTER_TARGETS_PATH=internhunter/config/targets.yaml
INTERNHUNTER_CONNECTIONS_PATH=internhunter/config/connections.yaml

# --- Wellfound (opt-in; see docs — ToS-restricted, bot-walled) ---
INTERNHUNTER_ENABLE_WELLFOUND=false
INTERNHUNTER_WELLFOUND_COMPANIES=
